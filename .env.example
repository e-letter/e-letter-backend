APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
SCHOOL_CODE=SMKN2SGS

# Email — Resend settings for OTP delivery
# Leave RESEND_API_KEY empty to disable delivery and fall back to console logging only.
RESEND_API_KEY=your_resend_api_key

# Optional: override the from address. Default is "SiPena <noreply@eletter.dedyn.io>"
# EMAIL_FROM=SiPena <noreply@eletter.dedyn.io>

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=db_eletter
DB_TLS=true                          # "true", "skip-verify", or empty for no TLS (required for Azure MariaDB)

JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=720h

ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password

CORS_ALLOWED_ORIGINS=your_cors_url

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting — Login (IP+UA composite key — handles school NAT)
RATE_LIMIT_LOGIN_MAX=50
RATE_LIMIT_LOGIN_WINDOW=5m
RATE_LIMIT_LOGIN_ADMIN_MAX=10
RATE_LIMIT_LOGIN_ADMIN_WINDOW=5m

# Rate Limiting — Registration (IP+UA composite key)
RATE_LIMIT_REGISTER_MAX=10
RATE_LIMIT_REGISTER_WINDOW=10m

# Rate Limiting — Password Reset Flow (IP+UA composite key)
RATE_LIMIT_FORGOT_PASSWORD_MAX=5
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=15m
RATE_LIMIT_VERIFY_OTP_MAX=10
RATE_LIMIT_VERIFY_OTP_WINDOW=10m
RATE_LIMIT_RESET_PASSWORD_MAX=5
RATE_LIMIT_RESET_PASSWORD_WINDOW=15m

# Rate Limiting — Token Refresh (IP+UA composite key)
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_REFRESH_WINDOW=5m

# Rate Limiting — Write Operations (user-based)
RATE_LIMIT_WRITE_MAX=40
RATE_LIMIT_WRITE_WINDOW=5m

# Rate Limiting — Read Operations (user-based)
RATE_LIMIT_READ_MAX=300
RATE_LIMIT_READ_WINDOW=1m

# Rate Limiting — SSE (user-based)
RATE_LIMIT_SSE_MAX=3
RATE_LIMIT_SSE_WINDOW=30s

# Rate Limiting — Admin Panel (user-based)
RATE_LIMIT_ADMIN_MAX=300
RATE_LIMIT_ADMIN_WINDOW=1m

# Rate Limiting — Dev Endpoints (IP+UA composite key)
RATE_LIMIT_DEV_MAX=60
RATE_LIMIT_DEV_WINDOW=1m

# Rate Limiting — Global Fallback (IP+UA composite key)
RATE_LIMIT_GLOBAL_MAX=2000
RATE_LIMIT_GLOBAL_WINDOW=1m
